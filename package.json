{
  "name": "react-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/y3zai/photo-selector.git"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "cf:dev": "npm run build && wrangler dev",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"npm run dev -- --mode electron\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:release": "vite build --mode electron && electron-builder --publish onTag"
  },
  "build": {
    "appId": "ai.y3z.photo-selector",
    "productName": "Photo Selector",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.photography",
      "artifactName": "Photo-Selector-${version}-${arch}.${ext}"
    },
    "win": {
      "target": "nsis",
      "artifactName": "Photo-Selector-Setup-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "Photo-Selector-${version}.${ext}"
    },
    "publish": {
      "provider": "github"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1",
    "wrangler": "^4.81.1"
  }
}
